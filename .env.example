APP_NAME="Amir Islamic Collection"
APP_ENV=production
APP_URL=https://your-app.onrender.com
APP_DEBUG=false

# Database (set DB_DRIVER=pgsql for Supabase/PostgreSQL, or mysql for local MySQL)
DB_DRIVER=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amir_islamic_db
DB_USER=postgres
DB_PASS=

# For Supabase:
# DB_DRIVER=pgsql
# DB_HOST=db.xxxxxxxxxxxxxxx.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASS=your-supabase-db-password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@amirislaminiccollection.com
SMTP_FROM_NAME="Amir Islamic Collection"

MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback
MPESA_ENV=sandbox

SITE_NAME="Amir Islamic Collection"
SITE_EMAIL=info@amirislaminiccollection.com
SITE_PHONE=+254712345678
SITE_ADDRESS="Nairobi, Kenya"
SITE_CURRENCY=KES
SITE_TAX=16
